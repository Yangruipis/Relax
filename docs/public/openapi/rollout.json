    "/scale_out_cancel": {
      "post": {
        "summary": "Cancel All Scale Out Requests",
        "description": "Cancel all scale-out requests matching criteria.\n\nStatus Codes:\n    200: Success (some/all requests cancelled or previewed)\n    400: Invalid filter values (e.g., bad status name)\n    500: Internal server error\n\nExamples:\n    # 1. Preview what would be cancelled (dry-run)\n    curl -X POST http://localhost:8000/rollout/scale_out_cancel \\\n      -H \"Content-Type: application/json\" \\\n      -d '{\"dry_run\": true}'\n\n    # 2. Cancel all PENDING requests\n    curl -X POST http://localhost:8000/rollout/scale_out_cancel \\\n      -H \"Content-Type: application/json\" \\\n      -d '{\"status_filter\": \"PENDING\"}'\n\n    # 3. Cancel all PENDING requests for 'actor' model\n    curl -X POST http://localhost:8000/rollout/scale_out_cancel \\\n      -H \"Content-Type: application/json\" \\\n      -d '{\"model_name\": \"actor\", \"status_filter\": \"PENDING\"}'\n\n    # 4. Cancel all requests for 'actor' model\n    curl -X POST http://localhost:8000/rollout/scale_out_cancel \\\n      -H \"Content-Type: application/json\" \\\n      -d '{\"model_name\": \"actor\"}'",
        "operationId": "cancel_all_scale_out_requests_scale_out_cancel_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CancelAllScaleOutRequestsRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CancelAllScaleOutRequestsResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
